# PostgreSQL
POSTGRES_USER=healthcare
POSTGRES_PASSWORD=healthcare_secret
POSTGRES_DB=healthcare

# Auth Service
AUTH_DATABASE_URL=postgresql+asyncpg://healthcare:healthcare_secret@postgres:5432/auth_db
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Patient Service
PATIENT_DATABASE_URL=postgresql+asyncpg://healthcare:healthcare_secret@postgres:5432/patient_db

# Appointment Service
APPOINTMENT_DATABASE_URL=postgresql+asyncpg://healthcare:healthcare_secret@postgres:5432/appointment_db

# Clinical Notes Service
CLINICAL_NOTES_DATABASE_URL=postgresql+asyncpg://healthcare:healthcare_secret@postgres:5432/clinical_notes_db

# Billing Service
BILLING_DATABASE_URL=postgresql+asyncpg://healthcare:healthcare_secret@postgres:5432/billing_db

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
